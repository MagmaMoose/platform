{
  "name": "@calebsargeant/diatreme",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "npm run typecheck && npm test && npx wrangler deploy --dry-run --outdir .wrangler/dry-run",
    "coverage": "vitest run --coverage --coverage.provider=v8 --coverage.reporter=text --coverage.reporter=cobertura --coverage.reportsDirectory=coverage",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "jose": "6.2.3"
  },
  "devDependencies": {
    "@types/node": "25.9.2",
    "@vitest/coverage-v8": "4.1.8",
    "typescript": "6.0.3",
    "vitest": "4.1.8",
    "wrangler": "4.98.0"
  }
}
