# Chargate pinned scanner versions — single source of truth.
#
# Sourced by scripts/ci-install-tools.sh (CI installs) and scripts/lint-kustomize.sh
# (kubeconform / kube-score docker tags). Bumped automatically by
# scripts/bump-tool-versions.py via .github/workflows/update-tools.yaml, which only
# releases a new Chargate version if the bumped tools still pass CI (strict mode).
#
# Format notes: TRIVY/TRUFFLEHOG/KUBECONFORM/KUBE_SCORE keep a leading "v";
# the rest are bare semver. Do not add inline comments on the KEY=VALUE lines.
TRIVY_VERSION=v0.71.0
SEMGREP_VERSION=1.164.0
HADOLINT_VERSION=2.14.0
ACTIONLINT_VERSION=1.7.12
KUSTOMIZE_VERSION=5.8.1
TRUFFLEHOG_VERSION=v3.95.5
CHECKOV_VERSION=3.2.532
PIP_AUDIT_VERSION=2.10.0
KUBECONFORM_VERSION=v0.7.0
KUBE_SCORE_VERSION=v1.20.0
